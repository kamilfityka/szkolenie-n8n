# =============================================================================
# SZKOLENIE n8n — zmienne środowiskowe dla docker-compose.prod.yaml
# =============================================================================
# 1. Skopiuj ten plik: cp .env.prod.example .env.prod
# 2. Uzupełnij wszystkie wartości oznaczone jako CHANGE_ME
# 3. Uruchom: docker compose -f docker-compose.prod.yaml --env-file .env.prod up -d
# =============================================================================

# --- PostgreSQL (admin) -------------------------------------------------------
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=CHANGE_ME

# --- Użytkownik n8n w PostgreSQL (wspólny dla wszystkich instancji) -----------
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=CHANGE_ME

# --- Adres IP / hostname VPS --------------------------------------------------
# Wpisz publiczny adres IP serwera (bez http://, bez portu)
# Przykład: VPS_IP=1.2.3.4
VPS_IP=CHANGE_ME

# --- Klucze szyfrowania n8n (unikalne per instancja) --------------------------
# Wygeneruj losowe klucze, np.: openssl rand -hex 24
# Każda instancja MUSI mieć własny, unikalny klucz.
N8N_01_ENCRYPTION_KEY=CHANGE_ME
N8N_02_ENCRYPTION_KEY=CHANGE_ME
N8N_03_ENCRYPTION_KEY=CHANGE_ME
N8N_04_ENCRYPTION_KEY=CHANGE_ME
N8N_05_ENCRYPTION_KEY=CHANGE_ME
N8N_06_ENCRYPTION_KEY=CHANGE_ME
N8N_07_ENCRYPTION_KEY=CHANGE_ME
N8N_08_ENCRYPTION_KEY=CHANGE_ME
N8N_09_ENCRYPTION_KEY=CHANGE_ME
N8N_10_ENCRYPTION_KEY=CHANGE_ME
N8N_11_ENCRYPTION_KEY=CHANGE_ME
N8N_12_ENCRYPTION_KEY=CHANGE_ME
N8N_13_ENCRYPTION_KEY=CHANGE_ME
N8N_14_ENCRYPTION_KEY=CHANGE_ME
N8N_15_ENCRYPTION_KEY=CHANGE_ME
N8N_16_ENCRYPTION_KEY=CHANGE_ME
N8N_17_ENCRYPTION_KEY=CHANGE_ME
N8N_18_ENCRYPTION_KEY=CHANGE_ME
N8N_19_ENCRYPTION_KEY=CHANGE_ME
N8N_20_ENCRYPTION_KEY=CHANGE_ME

# =============================================================================
# Szybkie generowanie kluczy (uruchom na VPS, wklej wyniki powyżej):
#   for i in $(seq 1 20); do echo "N8N_$(printf '%02d' $i)_ENCRYPTION_KEY=$(openssl rand -hex 24)"; done
# =============================================================================
